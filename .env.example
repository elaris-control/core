# ELARIS Core — Environment Configuration
# Copy this file to .env and adjust values

# Server port
PORT=8080

# Environment (development / production)
# Set to production on a real install — the server will refuse to start
# if ENGINEER_CODE / ENGINEER_SECRET / APP_SECRET are missing when production.
NODE_ENV=production

# MQTT broker URL
MQTT_URL=mqtt://localhost:1883

# --- Production only (leave blank for development) ---

# Engineer unlock code (protects commissioning access)
ENGINEER_CODE=
ENGINEER_SECRET=

# App secret for JWT signing
APP_SECRET=

# OAuth — Google (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# External URL (needed for OAuth redirects)
APP_URL=http://localhost:8080

# Reverse proxy (nginx, Cloudflare, etc.)
# Set to 1 if Elaris runs behind a reverse proxy so that rate-limiting uses
# the real client IP from X-Forwarded-For instead of the proxy IP.
# Leave blank or omit when running directly (no proxy in front).
TRUST_PROXY=
